{
	"name": "PictoCat",
	"author": [
		"Saucy"
	],
	"version": "0.2.0",
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:PictoCat",
	"descriptionmsg": "pictocat-desc",
	"license-name": "GPL-2.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.45.0",
		"extensions": {
			"PageImages": "*"
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\PictoCat\\": "includes/"
	},
	"config": {
		"PictoCatDefaultStyle": {
			"description": "Default PictoCat display style. Should be one of \"bullet\" or \"none\". This is mostly for futureproofing; at the moment this setting is pretty much useless.",
			"value": "bullet"
		},
		"PictoCatActivationPercentage": {
			"description": "The minimum percentage of pages in a category that must have a page image for PictoCat to activate.",
			"value": 50
		}
	},
	"HookHandlers": {
		"PictoCatHooks": {
			"class": "MediaWiki\\Extension\\PictoCat\\Hooks"
		}
	},
	"Hooks": {
		"ArticleFromTitle": "PictoCatHooks",
		"OutputPageParserOutput": "PictoCatHooks",
		"CategoryViewer::doCategoryQuery": "PictoCatHooks",
		"GetDoubleUnderscoreIDs": "PictoCatHooks",
		"GetPreferences": "PictoCatHooks"
	},
	"MessagesDirs": {
		"PictoCat": [
			"i18n"
		]
	},
	"ExtensionMessagesFiles": {
		"PictoCatMagic": "PictoCat.i18n.magic.php"
	},
	"DefaultUserOptions": {
		"pictocat": "default"
	},
	"ResourceModules": {
		"ext.pictoCat.bullet": {
			"localBasePath": "resources/ext.pictoCat",
			"remoteExtPath": "PictoCat/resources/ext.pictoCat",
			"styles": "ext.pictoCat.bullet.styles.less",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexStyleOnly": "true",
			"codexComponents": [
				"CdxThumbnail"
			]
		}
	},
	"manifest_version": 2
}
